# ─── App ───────────────────────────────────────────
APP_NAME="Rewaj Corporate Limited API"
DEBUG=False
SECRET_KEY=your-super-secret-key-change-this-in-production

# ─── Database ──────────────────────────────────────
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/rewaj_db

# ─── CORS ──────────────────────────────────────────
# Comma-separated list handled in config.py
ALLOWED_ORIGINS=["http://localhost:3000","https://rewajcorporate.com"]

# ─── Email (SendGrid) ──────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=noreply@rewajcorporate.com
ADMIN_EMAIL=info@rewajcorporate.com

# ─── Default Admin Account (change after first login) ──
ADMIN_EMAIL_DEFAULT=info@rewajcorporate.com
ADMIN_PASSWORD_DEFAULT=ChangeMe123!
